# ============================================================
# GitLab CI/CD Variables (set in GitLab > Settings > CI/CD)
# Workflow rules in .gitlab-ci.yml resolve _STAGING / _PROD
# variants based on branch (dev → staging, main → prod).
# ============================================================

# --- Docker Hub credentials (shared) ---
DOCKER_USERNAME=hitekhub
DOCKER_PASSWORD=

# --- Server SSH (single server for both envs) ---
SERVER_HOST=
SERVER_USER=
SERVER_PEM_FILE=                    # type: File (upload PEM key)

# Note: DEPLOY_PATH is set per branch in workflow rules
#   dev  → /opt/khpt-staging
#   main → /opt/khpt-prod

# ============================================================
# Frontend build-time env vars (Vite/Next.js)
# Pipeline reads _STAGING / _PROD variant based on branch.
# ============================================================

# --- FE Admin (Vite) — STAGING ---
VITE_API_URL_STAGING=https://cms-api-staging.fengshuimasteracademy.com/api/admin
VITE_COOKIE_KEY_SECRET_STAGING=
VITE_SUPPORT_LANGUAGE_STAGING=true
VITE_GOOGLE_MAP_API_KEY_STAGING=

# --- FE Admin (Vite) — PROD ---
VITE_API_URL_PROD=https://cms-api.fengshuimasteracademy.com/api/admin
VITE_COOKIE_KEY_SECRET_PROD=
VITE_SUPPORT_LANGUAGE_PROD=true
VITE_GOOGLE_MAP_API_KEY_PROD=

# --- FE Website (Next.js) — STAGING ---
NEXT_PUBLIC_API_URL_STAGING=https://app-api-staging.fengshuimasteracademy.com/api
NEXT_PUBLIC_IS_SUPPORT_LANGUAGE_STAGING=true

# --- FE Website (Next.js) — PROD ---
NEXT_PUBLIC_API_URL_PROD=https://app-api.fengshuimasteracademy.com/api
NEXT_PUBLIC_IS_SUPPORT_LANGUAGE_PROD=true
