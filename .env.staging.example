# ============================================================
# Backend env file — STAGING
# Lives at: /opt/khpt-staging/.env.staging on the server
# Loaded by: docker-compose.staging.yml (env_file)
# Used by: be-admin (port 4001) + be-website (port 4002)
# ============================================================

# --- Server ---
PORT=4001                            # be-admin uses 4001, be-website uses 4002
NODE_ENV=staging

# --- Database (shared Postgres instance, see docker-compose.infra.yml) ---
DB_HOST=khpt-postgres                # Container name on khpt-shared-net
DB_PORT=5432
DB_USERNAME=khpt_staging
DB_PASSWORD=                         # set in real .env.staging on server
DB_DATABASE=khpt_staging

# --- JWT ---
JWT_SECRET=                          # 32+ random chars, DIFFERENT from prod
JWT_EXPIRATION=7d

# --- Mail (SMTP) ---
# WARNING: staging uses real SMTP. Use test recipients only.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=                           # Gmail app password
MAIL_FROM=KHPT Staging <staging-noreply@fengshui.vn>

# --- CORS / Frontend URLs ---
FRONTEND_ADMIN_URL=https://cms-staging.fengshuimasteracademy.com
FRONTEND_WEBSITE_URL=https://staging.fengshuimasteracademy.com
CORS_ORIGINS=https://cms-staging.fengshuimasteracademy.com,https://staging.fengshuimasteracademy.com
