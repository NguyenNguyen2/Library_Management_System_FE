# ============================================================
# Backend env file — PRODUCTION
# Lives at: /opt/khpt-prod/.env.prod on the server
# Loaded by: docker-compose.prod.yml (env_file)
# Used by: be-admin (port 4001) + be-website (port 4002)
# ============================================================

# --- Server ---
PORT=4001                            # be-admin uses 4001, be-website uses 4002
NODE_ENV=production

# --- Database (shared Postgres instance, see docker-compose.infra.yml) ---
DB_HOST=khpt-postgres                # Container name on khpt-shared-net
DB_PORT=5432
DB_USERNAME=khpt_prod
DB_PASSWORD=                         # set in real .env.prod on server
DB_DATABASE=khpt_prod

# --- JWT ---
JWT_SECRET=                          # 32+ random chars, DIFFERENT from staging
JWT_EXPIRATION=7d

# --- Mail (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=                           # Gmail app password
MAIL_FROM=Khoa Hoc Phong Thuy <noreply@fengshui.vn>

# --- CORS / Frontend URLs ---
FRONTEND_ADMIN_URL=https://cms.fengshuimasteracademy.com
FRONTEND_WEBSITE_URL=https://fengshuimasteracademy.com
CORS_ORIGINS=https://cms.fengshuimasteracademy.com,https://fengshuimasteracademy.com,https://www.fengshuimasteracademy.com
