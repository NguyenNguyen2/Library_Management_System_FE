# ============================================================
# Infra env file — Postgres + Nginx (shared, owned by ops)
# Lives at: /opt/khpt-infra/.env.infra on the server
# Loaded by: docker-compose.infra.yml
# ============================================================

# Postgres bootstrap superuser (only used at first init)
# Both staging + prod databases live in this single instance.
# Create per-env users via postgres/init/01-create-dbs.sql
POSTGRES_USER=khpt
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
